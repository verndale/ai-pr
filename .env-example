# Copy to `.env` in the project root. The CLI loads `.env` then `.env.local` (override).

# GitHub token (repo scope). The CLI reads GH_TOKEN or GITHUB_TOKEN — set one when you run
# `ai-pr` locally. For CI-only PR creation, configure the workflow / repo secrets instead;
# you do not need a local `.env` unless you run the CLI on your machine.
# GH_TOKEN=

# Optional — PR behavior
# PR_BASE_BRANCH=main
# PR_DRAFT=true

# Optional — AI summary + labels (when PR_AI=true). CI can use repository variables / secrets;
# uncomment here for local `pnpm run pr:create` with AI.
# PR_AI=true
# PR_AI_ENDPOINT=https://api.openai.com/v1/responses
# PR_AI_API_KEY=
# PR_AI_MODEL=default

# @verndale/ai-commit — OPENAI_API_KEY: OpenAI API key for conventional commit messages (ai-commit run; optional for prepare-commit-msg with AI).
#OPENAI_API_KEY=

# @verndale/ai-commit — COMMIT_AI_MODEL: OpenAI model for commit messages (optional; default gpt-4o-mini).
# COMMIT_AI_MODEL=
