# Copy to `.env` in the project root. The CLI loads `.env` then `.env.local` (override).

# Required for @verndale/ai-pr (also accepts GITHUB_TOKEN)
GH_TOKEN=

# Optional — PR behavior
# PR_BASE_BRANCH=main
# PR_DRAFT=true

# Optional — AI summary + labels (when PR_AI=true). In this repo, CI reads these from
# GitHub → Settings → Secrets and variables → Actions (see README). Uncomment and set
# here only if you run `pnpm run pr` locally with AI.
# PR_AI=true
# PR_AI_ENDPOINT=https://api.openai.com/v1/responses
# PR_AI_API_KEY=
# PR_AI_MODEL=default

# @verndale/ai-commit (this repo only — maintainer hooks / pnpm run commit; not shipped in the published package)
# OPENAI_API_KEY=
# COMMIT_AI_MODEL=
